{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | grep -qE 'Cargo[.](toml|lock)$' && cargo audit 2>/dev/null || true",
            "timeout": 120,
            "statusMessage": "Running cargo audit..."
          }
        ]
      }
    ]
  }
}
