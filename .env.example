# Database
DATABASE_URL=sqlite://data/myapps.db

# Public URL (used to build callback URIs, etc.)
# Path component becomes the URL prefix (e.g. /myapps)
BASE_URL=http://localhost:3000

# Encryption key for storing sensitive credentials (32-byte hex string)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Web Push notifications (generate with: cargo run -- generate-vapid-keys)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Voice-to-Text (whisper.cpp)
WHISPER_CLI_PATH=whisper-cli
WHISPER_MODELS_DIR=models

# Command Bar (llama.cpp server) — optional, command bar hidden when unset
LLAMA_SERVER_URL=

# Server
BIND_ADDR=127.0.0.1:3000

# Subset of apps to deploy (comma-separated app keys, blank = all)
# Valid keys: leanfin, mindflow, voice_to_text, classroom_input
DEPLOY_APPS=
