# Database
DATABASE_URL=sqlite://data/leanfin.db

# Encryption key for bank tokens (64-char hex = 256-bit key)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Enable Banking
ENABLE_BANKING_APP_ID=
ENABLE_BANKING_REDIRECT_URI=http://localhost:3000/accounts/callback

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Server
BIND_ADDR=127.0.0.1:3000

# URL prefix when served behind a reverse proxy subpath (e.g. /leanfin)
# Leave empty if served at root
BASE_PATH=
