# Database
DATABASE_URL=sqlite://data/myapps.db

# Public URL (used to build callback URIs, etc.)
# Path component becomes the URL prefix (e.g. /myapps)
BASE_URL=http://localhost:3000

# Enable Banking (LeanFin)
ENABLE_BANKING_APP_ID=
ENABLE_BANKING_KEY_PATH=private.pem

# Notifications (ntfy)
NTFY_URL=http://127.0.0.1:8090
NTFY_TOPIC=

# Timezone (IANA format, e.g. Europe/Madrid, America/New_York)
TIMEZONE=Europe/Madrid

# Server
BIND_ADDR=127.0.0.1:3000
