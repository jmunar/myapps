# Production deploy configuration
# Copy to prod.env and fill in DEPLOY_DOMAIN and DEPLOY_SERVER.
DEPLOY_DOMAIN=
DEPLOY_SERVER=
DEPLOY_GH_ENVIRONMENT=production
DEPLOY_REMOTE_DIR=/opt/myapps
DEPLOY_REMOTE_BUILD_DIR="~/myapps-stage-build"
DEPLOY_SERVICE_NAME=myapps
DEPLOY_NGINX_SITE=myapps
DEPLOY_PORT=3000
DEPLOY_CRON_ENABLED=true
DEPLOY_ICON=icon.svg
DEPLOY_SEED=false
# Comma-separated app keys to deploy (blank = all)
DEPLOY_APPS=""
# SSO header from reverse proxy (e.g. Remote-User for Authelia). Empty = password login.
DEPLOY_AUTH_SSO_HEADER=""
# External app shortcuts (key|name|desc|icon|url;...)
DEPLOY_EXTERNAL_APPS=""
