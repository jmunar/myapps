# Staging deploy configuration
# Copy to stage.env and fill in DEPLOY_DOMAIN and DEPLOY_SERVER.
DEPLOY_DOMAIN=
DEPLOY_SERVER=
DEPLOY_GH_ENVIRONMENT=staging
DEPLOY_REMOTE_DIR=/opt/myapps-stage
DEPLOY_REMOTE_BUILD_DIR="~/myapps-stage-build"
DEPLOY_SERVICE_NAME=myapps-stage
DEPLOY_NGINX_SITE=myapps-stage
DEPLOY_PORT=3001
DEPLOY_CRON_ENABLED=false
DEPLOY_ICON=icon-stage.svg
DEPLOY_SEED=true
# Comma-separated app keys to deploy (blank = all)
DEPLOY_APPS=""
# External app shortcuts (key|name|desc|icon|url;...)
DEPLOY_EXTERNAL_APPS=""
